%         th = theta_cycle(i);
%         A = [a*cos(th), a*sin(th)];
%         slider_x = a*cos(th) + sqrt(b^2 - (a*sin(th))^2);
%         B = [slider_x, 0];  
%         set(ll, 'XData', [0, A(1), B(1)], 'YData', [0, A(2), B(2)]);
