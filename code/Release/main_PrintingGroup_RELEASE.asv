tt=time;
ww=tetha;
signal1 = Simulink.SimulationData.Signal;
signal1.Name = 'pos';
signal1.Values = timeseries(ww, tt);
ds = Simulink.SimulationData.Dataset;
ds = addElement(ds, signal1, 'position');
save('pos.mat', 'ds');


